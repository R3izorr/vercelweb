---
import { Icon } from 'astro-icon/components';
import ThemeToggle from './ThemeToggle.astro';
import links from '../data/links.json';

type Item = { url: string; title: string };

type Props = { items: Item[] };

const { items } = Astro.props as Props;
const path = Astro.url.pathname;
const active = (url: string) => (url === '/' ? path === '/' : path.startsWith(url));
const quickLinks = links.filter((l) => l.label === 'GitHub' || l.label === 'LinkedIn');
const repoLink = links.find((l) => l.label === 'CTF Writeup repo');
---

<header class="site-header" id="site-header">
  <div class="site-wrap">
    <div class="site-header-inner">
      <a href="/" class="brand" aria-label="r3izorr home">
        <span class="brand-mark">R3</span>
        <span class="brand-text">
          <span class="brand-name">r3izorr</span>
          <span class="brand-sub">security notes</span>
        </span>
      </a>

      <div class="nav-shell">
        <nav class="nav" data-nav aria-label="Main">
          {
            items.map((item) => (
              <a
                href={item.url}
                aria-current={active(item.url) ? 'page' : undefined}
              >
                {item.title}
              </a>
            ))
          }
          {
            repoLink && (
              <a href={repoLink.url} target="_blank" rel="noopener noreferrer">
                CTF repo
              </a>
            )
          }
        </nav>

        <div class="header-actions">
          {
            quickLinks.map((l) => (
              <a
                href={l.url}
                target="_blank"
                rel="noopener noreferrer"
                class="icon-link"
                aria-label={l.label}
                title={l.label}
              >
                <Icon name={l.icon} class="w-4 h-4" />
              </a>
            ))
          }
          <ThemeToggle />
          <button class="menu-btn" type="button" data-menu-toggle aria-label="Toggle menu">
            MENU
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');

  toggle?.addEventListener('click', () => {
    const open = nav?.dataset.open === 'true';
    if (!nav) return;
    nav.dataset.open = open ? 'false' : 'true';
    toggle.setAttribute('aria-expanded', String(!open));
  });
</script>
