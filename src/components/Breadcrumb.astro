---
import { Icon } from 'astro-icon/components';

type Crumb = { label: string; href: string };
type Props = { items: Crumb[]; class?: string };

const { items, class: classList } = Astro.props as Props;
---

<nav class:list={['text-xs text-[color:var(--color-tx-2)]', classList]}>
  <ol class="flex flex-wrap items-center gap-1">
    {
      items.map((item, index) => (
        <li class="inline-flex items-center gap-1">
          {index !== 0 && <Icon name="lucide:chevron-right" class="w-3 h-3 opacity-60" />}
          {index === items.length - 1 ? (
            <span class="text-[color:var(--color-tx)]">{item.label}</span>
          ) : (
            <a href={item.href} class="hover:text-[color:var(--color-accent-600)] dark:hover:text-[color:var(--color-accent-400)]">
              {item.label}
            </a>
          )}
        </li>
      ))
    }
  </ol>
</nav>
