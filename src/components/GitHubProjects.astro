---
import { Icon } from 'astro-icon/components';
import Card from './Core/Card.astro';
import { visibleRepos } from '../lib/github';
import { langColor, formatMonthYear, truncate } from '../lib/format';

type Props = { limit?: number };
const { limit } = Astro.props as Props;

let repos = visibleRepos();
if (limit) repos = repos.slice(0, limit);
---

<div class="grid gap-3 sm:grid-cols-2">
  {
    repos.map((r) => (
      <Card href={r.htmlUrl} class="flex flex-col gap-2">
        <div class="flex items-center justify-between gap-2">
          <div class="flex items-center gap-2 min-w-0">
            <Icon
              name="lucide:book-marked"
              class="w-3.5 h-3.5 text-[color:var(--color-tx-3)] shrink-0"
            />
            <span class="text-sm font-medium truncate">{r.name}</span>
          </div>
          <Icon
            name="lucide:arrow-up-right"
            class="w-3 h-3 text-[color:var(--color-tx-3)]"
          />
        </div>
        <p class="text-xs text-[color:var(--color-tx-2)] line-clamp-2 min-h-[1.8em]">
          {truncate(r.description, 120) || 'No description.'}
        </p>
        <div class="flex items-center flex-wrap gap-2 text-[11px] text-[color:var(--color-tx-3)] mt-auto pt-1">
          {r.language && (
            <span class="flex items-center gap-1">
              <span
                class="inline-block w-2 h-2 rounded-full"
                style={`background:${langColor(r.language)}`}
              />
              {r.language}
            </span>
          )}
          {r.stargazersCount > 0 && (
            <span class="flex items-center gap-1">
              <Icon name="lucide:star" class="w-3 h-3" /> {r.stargazersCount}
            </span>
          )}
          {r.forksCount > 0 && (
            <span class="flex items-center gap-1">
              <Icon name="lucide:git-fork" class="w-3 h-3" /> {r.forksCount}
            </span>
          )}
          <span class="ml-auto font-mono">{formatMonthYear(r.pushedAt)}</span>
        </div>
      </Card>
    ))
  }
</div>
