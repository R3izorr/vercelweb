---
import type { HTMLAttributes } from 'astro/types';
import { twMerge } from 'tailwind-merge';

type Props = HTMLAttributes<'span'> & {
  tone?: 'default' | 'accent' | 'sky' | 'amber' | 'rose' | 'violet' | 'orange';
};

const { class: classList, tone = 'default', ...rest } = Astro.props as Props;

const toneClasses: Record<NonNullable<Props['tone']>, string> = {
  default: '',
  accent:
    'text-[color:var(--color-accent-700)] border-[color:var(--color-accent-500)]/40',
  sky: 'text-[color:var(--color-sky-accent)] border-[color:var(--color-sky-accent)]/40',
  amber:
    'text-[color:var(--color-amber-accent)] border-[color:var(--color-amber-accent)]/40',
  rose: 'text-[color:var(--color-rose-accent)] border-[color:var(--color-rose-accent)]/40',
  violet:
    'text-[color:var(--color-violet-accent)] border-[color:var(--color-violet-accent)]/40',
  orange:
    'text-[color:var(--color-orange-accent)] border-[color:var(--color-orange-accent)]/40',
};
---

<span class={twMerge('chip', toneClasses[tone], classList as string | undefined)} {...rest}>
  <slot />
</span>
