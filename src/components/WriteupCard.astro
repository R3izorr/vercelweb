---
import { Icon } from 'astro-icon/components';
import Card from './Core/Card.astro';
import Chip from './Core/Chip.astro';
import {
  CATEGORY_LABELS,
  CATEGORY_ICONS,
  CATEGORY_TONE,
  writeupHref,
  type WriteupEntry,
} from '../lib/writeups';
import { formatDate } from '../lib/format';

type Props = { entry: WriteupEntry; showEvent?: boolean };
const { entry, showEvent = true } = Astro.props as Props;
const d = entry.data;
const href = writeupHref(entry);
const catIcon = CATEGORY_ICONS[d.category] ?? 'lucide:tag';
const catLabel = CATEGORY_LABELS[d.category] ?? d.category;
const tone = CATEGORY_TONE[d.category] ?? 'default';
---

<Card href={href} class="flex flex-col gap-2">
  <div class="flex items-start justify-between gap-3">
    <div>
      <div class="text-sm font-semibold">{d.title}</div>
      {showEvent && (
        <div class="text-[11px] text-[color:var(--color-tx-3)] mt-0.5">
          {d.event} · {d.year}
          {d.date && (
            <>
              {' · '}
              <span class="font-mono">{formatDate(d.date)}</span>
            </>
          )}
        </div>
      )}
    </div>
    <Chip tone={tone}>
      <Icon name={catIcon} class="w-3 h-3" />
      {catLabel}
    </Chip>
  </div>
  {d.description && (
    <p class="text-xs text-[color:var(--color-tx-2)] leading-relaxed line-clamp-2">
      {d.description}
    </p>
  )}
  <div class="flex items-center justify-between text-[11px] text-[color:var(--color-tx-3)] mt-auto pt-1">
    <div class="flex flex-wrap gap-1">
      {d.tags.slice(0, 4).map((t) => <Chip>#{t}</Chip>)}
    </div>
    {d.difficulty && (
      <span class="uppercase font-mono">{d.difficulty}</span>
    )}
  </div>
</Card>
