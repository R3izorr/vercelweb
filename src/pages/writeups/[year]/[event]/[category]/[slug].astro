---
import { render } from 'astro:content';
import BlogLayout from '../../../../../layouts/BlogLayout.astro';
import Chip from '../../../../../components/Core/Chip.astro';
import { Icon } from 'astro-icon/components';
import {
  getWriteups,
  writeupSlugParts,
  CATEGORY_LABELS,
  CATEGORY_ICONS,
  CATEGORY_TONE,
} from '../../../../../lib/writeups';
import { formatDate } from '../../../../../lib/format';

export async function getStaticPaths() {
  const entries = await getWriteups({ includeDrafts: false });
  return entries.map((entry) => {
    const { year, event, category, slug } = writeupSlugParts(entry);
    return {
      params: { year, event, category, slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const d = entry.data;
const { event, slug } = writeupSlugParts(entry);
const { Content, headings } = await render(entry);
const catLabel = CATEGORY_LABELS[d.category] ?? d.category;
const catIcon = CATEGORY_ICONS[d.category] ?? 'lucide:tag';
const tone = CATEGORY_TONE[d.category] ?? 'default';

const sourceUrl =
  d.sourceRepo && d.sourcePath
    ? `https://github.com/${d.sourceRepo}/tree/main/${d.sourcePath}`
    : d.sourceRepo
      ? `https://github.com/${d.sourceRepo}`
      : null;
---

<BlogLayout
  title={`${d.title} — ${d.event} ${d.year}`}
  description={d.description}
  type="article"
  author="Chien Nguyen"
  headings={headings}
  breadcrumbs={[
    { label: 'Writeups', href: '/writeups' },
    { label: String(d.year), href: `/writeups/${d.year}` },
    { label: d.event, href: `/writeups/${d.year}/${event}` },
    { label: catLabel, href: `/writeups/${d.year}/${event}/${d.category}` },
    { label: d.title, href: `/writeups/${d.year}/${event}/${d.category}/${slug}` },
  ]}
>
  <header class="mb-6 not-prose">
    <div class="flex items-center gap-2 mb-3">
      <Chip tone={tone}>
        <Icon name={catIcon} class="w-3 h-3" />
        {catLabel}
      </Chip>
      {d.difficulty && (
        <span class="text-[11px] font-mono uppercase text-[color:var(--color-tx-3)]">
          {d.difficulty}
        </span>
      )}
      {typeof d.points === 'number' && (
        <span class="text-[11px] font-mono text-[color:var(--color-tx-3)]">
          {d.points} pts
        </span>
      )}
    </div>
    <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight m-0">
      {d.title}
    </h1>
    <div class="text-sm text-[color:var(--color-tx-2)] mt-2">
      {d.event} · <span class="font-mono">{d.year}</span>
      {d.date && (
        <>
          <span class="mx-1.5 text-[color:var(--color-tx-3)]">·</span>
          <span class="font-mono">{formatDate(d.date)}</span>
        </>
      )}
    </div>
    {d.description && (
      <p class="text-[color:var(--color-tx-2)] leading-relaxed mt-3 max-w-2xl">
        {d.description}
      </p>
    )}
    <div class="flex flex-wrap gap-1.5 mt-4">
      {d.tags.map((t) => (
        <a href={`/writeups/tags/${t}`}>
          <Chip>#{t}</Chip>
        </a>
      ))}
    </div>
    {sourceUrl && (
      <div class="mt-4">
        <a
          href={sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-ghost"
        >
          <Icon name="simple-icons:github" class="w-4 h-4" />
          source on GitHub
        </a>
      </div>
    )}
  </header>

  <Content />
</BlogLayout>
