---
import PageLayout from '../../../layouts/PageLayout.astro';
import Chip from '../../../components/Core/Chip.astro';
import { getTags } from '../../../lib/writeups';

const tags = await getTags();
---

<PageLayout
  title="Writeup tags — R3izorr"
  description="Browse CTF writeups by tag"
  breadcrumbs={[
    { label: 'Writeups', href: '/writeups' },
    { label: 'Tags', href: '/writeups/tags' },
  ]}
>
  <header class="mb-6">
    <h1 class="text-2xl font-semibold tracking-tight">Tags</h1>
    <p class="text-sm text-[color:var(--color-tx-2)] mt-1">
      {tags.length} tag{tags.length === 1 ? '' : 's'}
    </p>
  </header>

  <div class="flex flex-wrap gap-1.5">
    {tags.map((t) => (
      <a href={`/writeups/tags/${t.tag}`}>
        <Chip>
          #{t.tag}
          <span class="text-[color:var(--color-tx-3)]">· {t.count}</span>
        </Chip>
      </a>
    ))}
  </div>
</PageLayout>
